# Dev Launcher Environment Configuration
# Copy this file to .env and customize for your environment

# Development directory where your projects are stored
# Supports ~ for home directory
DEV_ROOT=~/projects

# Default ports for different app types
# These can be overridden per app configuration. Use governed non-forbidden ports.
NEXTJS_DEFAULT_PORT=10010
VITE_DEFAULT_PORT=10020
PYTHON_DEFAULT_PORT=10030
STATIC_DEFAULT_PORT=10040

# Port allocation preferences
MAX_PORT_ATTEMPTS=10
PREFERRED_PORT_RANGE_START=10000
PREFERRED_PORT_RANGE_END=10100

# Browser preferences
BROWSER_APP=Google Chrome
# Available options: Google Chrome, Safari, Firefox, etc.

# Terminal preferences
TERMINAL_APP=Terminal.app
# Available options: Terminal.app, iTerm2, etc.

# UI preferences
AUTO_REFRESH_INTERVAL=2000
# How often to check for app status updates (milliseconds)

# Feature toggles
ENABLE_PROJECT_DISCOVERY=true
ENABLE_AUTO_BROWSER_OPEN=true
ENABLE_TERMINAL_OPEN=true

# Advanced settings
LOG_LEVEL=info
# Available: debug, info, warn, error
